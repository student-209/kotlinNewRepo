<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="#F5F5F5"
    android:layout_width="match_parent"
    android:layout_height="match_parent">


    <EditText
        android:id="@+id/txtDisplay"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:hint="0"
        android:textSize="36sp"
        android:textStyle="bold"
        android:gravity="end|center_vertical"
        android:enabled="false"
        android:background="#FFFFFF"
        android:padding="16dp"/>


    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:columnCount="4">


        <Button style="@style/CalcBtn" android:id="@+id/btn7" android:text="7"/>
        <Button style="@style/CalcBtn" android:id="@+id/btn8" android:text="8"/>
        <Button style="@style/CalcBtn" android:id="@+id/btn9" android:text="9"/>
        <Button style="@style/OpBtn" android:id="@+id/btnDivide" android:text="/"/>


        <Button style="@style/CalcBtn" android:id="@+id/btn4" android:text="4"/>
        <Button style="@style/CalcBtn" android:id="@+id/btn5" android:text="5"/>
        <Button style="@style/CalcBtn" android:id="@+id/btn6" android:text="6"/>
        <Button style="@style/OpBtn" android:id="@+id/btnMultiply" android:text="*"/>


        <Button style="@style/CalcBtn" android:id="@+id/btn1" android:text="1"/>
        <Button style="@style/CalcBtn" android:id="@+id/btn2" android:text="2"/>
        <Button style="@style/CalcBtn" android:id="@+id/btn3" android:text="3"/>
        <Button style="@style/OpBtn" android:id="@+id/btnMinus" android:text="-"/>


        <Button style="@style/CalcBtn" android:id="@+id/btn0" android:text="0"/>
        <Button style="@style/OpBtn" android:id="@+id/btnClear" android:text="C"/>
        <Button style="@style/OpBtn" android:id="@+id/btnEqual" android:text="="/>
        <Button style="@style/OpBtn" android:id="@+id/btnPlus" android:text="+"/>

    </GridLayout>

</LinearLayout>
